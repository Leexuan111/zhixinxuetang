page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.page-container {
  padding: 30rpx;
  padding-bottom: 120rpx;
}

.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 30rpx;
}

.app-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.app-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.app-subtitle {
  font-size: 26rpx;
  color: #999;
}

.action-area {
  padding: 40rpx 0;
}

.upload-btn {
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(74, 144, 217, 0.3);
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 34rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
}

.image-area {
  padding: 20rpx 0;
}

.image-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.preview-img {
  width: 100%;
  height: 400rpx;
}

.image-actions {
  display: flex;
  padding: 20rpx 30rpx;
  gap: 20rpx;
}

.btn-rechoose {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background: #f0f0f0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
}

.btn-reanalyze {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background: #4A90D9;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #fff;
}

.loading-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #e0e0e0;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.loading-hint {
  font-size: 24rpx;
  color: #999;
}

.result-area {
  padding-top: 10rpx;
}

.section-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-body {
  padding: 24rpx 30rpx;
}

.question-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  padding: 0 30rpx 24rpx;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.subject-tag {
  background: #e8f4fd;
  color: #4A90D9;
}

.kp-tag {
  background: #fff3e0;
  color: #f57c00;
}

.analysis-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

.question-card {
  background: #fafafa;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  border: 1rpx solid #eee;
}

.question-card:last-child {
  margin-bottom: 0;
}

.question-header {
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
}

.question-number {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
}

.question-content {
  padding: 24rpx;
}

.question-content text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
}

.answer-section {
  border-top: 1rpx solid #eee;
}

.answer-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #4A90D9;
}

.arrow {
  font-size: 20rpx;
  transition: transform 0.3s;
}

.arrow-up {
  display: inline-block;
  transform: rotate(180deg);
}

.arrow-down {
  display: inline-block;
}

.answer-content {
  padding: 20rpx 24rpx;
  background: #e8f4fd;
  border-top: 1rpx solid #d0e8f7;
}

.answer-content text {
  font-size: 26rpx;
  color: #444;
  line-height: 1.8;
}

.bottom-actions {
  display: flex;
  gap: 20rpx;
  padding: 30rpx 0;
}

.btn-primary {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
  box-shadow: 0 6rpx 20rpx rgba(74, 144, 217, 0.3);
}

.btn-secondary {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  background: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #4A90D9;
  font-weight: bold;
  border: 2rpx solid #4A90D9;
}
