page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.page-container {
  padding: 20rpx 30rpx;
  padding-bottom: 120rpx;
}

.empty-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.list-count {
  font-size: 26rpx;
  color: #999;
}

.clear-btn {
  font-size: 26rpx;
  color: #e74c3c;
  padding: 8rpx 20rpx;
  background: #fde8e8;
  border-radius: 20rpx;
}

.history-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.card-header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.card-subject {
  font-size: 24rpx;
  color: #4A90D9;
  background: #e8f4fd;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.card-time {
  font-size: 22rpx;
  color: #bbb;
}

.card-header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.delete-btn {
  font-size: 30rpx;
}

.expand-arrow {
  font-size: 22rpx;
  color: #999;
  transition: transform 0.3s;
}

.expand-arrow.arrow-up {
  display: inline-block;
  transform: rotate(180deg);
}

.expand-arrow.arrow-down {
  display: inline-block;
}

.card-preview {
  padding: 20rpx 30rpx;
}

.preview-text {
  font-size: 26rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.6;
}

.card-detail {
  border-top: 1rpx solid #f0f0f0;
  padding: 20rpx 30rpx;
}

.detail-section {
  margin-bottom: 24rpx;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.detail-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.detail-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.kp-tag {
  background: #fff3e0;
  color: #f57c00;
}

.similar-question {
  background: #fafafa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  border: 1rpx solid #eee;
}

.similar-question:last-child {
  margin-bottom: 0;
}

.sq-header {
  padding: 16rpx 20rpx;
  background: #4A90D9;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.sq-content {
  display: block;
  padding: 20rpx;
  font-size: 26rpx;
  color: #444;
  line-height: 1.8;
}

.answer-section {
  border-top: 1rpx solid #eee;
}

.answer-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: #4A90D9;
}

.arrow {
  font-size: 18rpx;
}

.arrow-up {
  display: inline-block;
  transform: rotate(180deg);
}

.arrow-down {
  display: inline-block;
}

.answer-content {
  padding: 16rpx 20rpx;
  background: #e8f4fd;
  font-size: 24rpx;
  color: #444;
  line-height: 1.8;
}
